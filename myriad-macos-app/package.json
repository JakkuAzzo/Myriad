{
  "name": "myriad-app",
  "version": "1.0.0",
  "description": "Myriad - privacy-first mindful habit tracker",
  "main": "electron/main.js",
  "scripts": {
    "start": "npm run rebuild:electron && electron .",
    "start:web": "node src/server.js",
    "dev": "node src/server.js",
    "test": "npm run rebuild:node && node --test",
    "demo:video": "node scripts/record-demo-video.mjs",
    "demo:ios-video": "node scripts/record-ios-simulator-video.mjs",
    "rebuild:node": "npm rebuild better-sqlite3",
    "rebuild:electron": "electron-rebuild -f -w better-sqlite3"
  },
  "keywords": [],
