  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "supertest": "^7.2.2",
    "@xenova/transformers": "^2.17.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "electron": "^40.8.0",
    "playwright": "^1.58.2"
  }
}
